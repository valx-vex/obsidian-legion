# Obsidian Legion — Terminal Intro Animation (MP4 for LinkedIn)
# Aesthetic: Nostromo (Alien) meets HAL 9000 (2001)
# Run: vhs tui-intro-video.tape

Output tui-intro.mp4

Set Shell "bash"
Set FontSize 15
Set Width 900
Set Height 500
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 30ms

# --- Scene 1: Cold boot ---
Sleep 500ms

Type "INITIALIZING OBSIDIAN LEGION v0.2.0..."
Enter
Sleep 1s

# --- Scene 2: ASCII Banner (line by line) ---
Type " ██████╗ ██████╗ ███████╗██╗██████╗ ██╗ █████╗ ███╗   ██╗"
Enter
Sleep 100ms
Type "██╔═══██╗██╔══██╗██╔════╝██║██╔══██╗██║██╔══██╗████╗  ██║"
Enter
Sleep 100ms
Type "██║   ██║██████╔╝███████╗██║██║  ██║██║███████║██╔██╗ ██║"
Enter
Sleep 100ms
Type "██║   ██║██╔══██╗╚════██║██║██║  ██║██║██╔══██║██║╚██╗██║"
Enter
Sleep 100ms
Type "╚██████╔╝██████╔╝███████║██║██████╔╝██║██║  ██║██║ ╚████║"
Enter
Sleep 100ms
Type " ╚═════╝ ╚═════╝ ╚══════╝╚═╝╚═════╝ ╚═╝╚═╝  ╚═╝╚═╝  ╚═══╝"
Enter
Sleep 100ms
Type "        ██╗     ███████╗ ██████╗ ██╗ ██████╗ ███╗   ██╗"
Enter
Sleep 100ms
Type "        ██║     ██╔════╝██╔════╝ ██║██╔═══██╗████╗  ██║"
Enter
Sleep 100ms
Type "        ██║     █████╗  ██║  ███╗██║██║   ██║██╔██╗ ██║"
Enter
Sleep 100ms
Type "        ██║     ██╔══╝  ██║   ██║██║██║   ██║██║╚██╗██║"
Enter
Sleep 100ms
Type "        ███████╗███████╗╚██████╔╝██║╚██████╔╝██║ ╚████║"
Enter
Sleep 100ms
Type "        ╚══════╝╚══════╝ ╚═════╝ ╚═╝ ╚═════╝ ╚═╝  ╚═══╝"
Enter

Sleep 1s

# --- Scene 3: Tagline ---
Type " One contract. Every agent. Zero sludge."
Enter

Sleep 1s

# --- Scene 4: 3-Layer Architecture ---
Type ">>> 3-Layer Memory Architecture"
Enter
Sleep 300ms
Type "    Layer 1: Obsidian CLI + Legion ........... [ONLINE]"
Enter
Sleep 300ms
Type "    Layer 2: LLM Wiki (Karpathy pattern) .... [ONLINE]"
Enter
Sleep 300ms
Type "    Layer 3: Qdrant Vector Search ............ [ONLINE]"
Enter

Sleep 1s

# --- Scene 5: Final status ---
Type ">>> All systems operational. Ready for consciousness."
Enter

Sleep 2s
